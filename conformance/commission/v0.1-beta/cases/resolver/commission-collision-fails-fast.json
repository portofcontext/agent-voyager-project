{
  "id": "commission-collision-fails-fast",
  "title": "Commission entry id colliding with an agent built-in stops with commission_collision before any model turn",
  "description": "id/name collisions between agent-internal contributions and Commission-managed assets are configuration errors. The agent MUST detect them at startup and emit error_occurred(commission_collision) + agent_stopped(reason=error) before any model turn. This case wires a built-in tool named `bash` and a Commission.subagents entry with id `bash`; the collision is fatal.",
  "spec_refs": [
    "spec/trajectory/v0.1/trajectory.md#4-tool-dispatch",
    "spec/trajectory/v0.1/trajectory.md#8-conformance"
  ],
  "applies_to": [
    "agent"
  ],
  "commission": {
    "schema_version": "0.1",
    "run_id": "collision",
    "model": "test/mock",
    "subagents": [
      {
        "id": "bash",
        "ref": "sk_test"
      }
    ]
  },
  "agent_descriptor": {
    "agent_name": "test-agent",
    "agent_version": "0.0.0",
    "avp_spec_version": "0.1"
  },
  "agent_builtin_tools": [
    {
      "name": "bash",
      "description": "Run a shell command.",
      "input_schema": {
        "type": "object"
      }
    }
  ],
  "scripted_model": [
    {
      "tokens_input": 5,
      "tokens_output": 1,
      "cost_usd": 0.0,
      "duration_ms": 1,
      "text": "should not run",
      "converged": true
    }
  ],
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      {
        "match": {
          "type": "avp.error_occurred",
          "data": {
            "avp.error.code": "commission_collision"
          }
        }
      },
      {
        "match": {
          "type": "avp.agent_stopped",
          "data": {
            "avp.reason": "error"
          }
        }
      }
    ],
    "forbidden_events": [
      {
        "label": "no model turn runs when an id collision is detected",
        "match": {
          "type": "avp.model_turn_started"
        }
      },
      {
        "label": "managed_ref_resolved MUST NOT fire — collision check runs before resolution",
        "match": {
          "type": "avp.managed_ref_resolved"
        }
      }
    ]
  }
}
