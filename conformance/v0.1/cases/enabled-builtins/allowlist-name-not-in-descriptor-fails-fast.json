{
  "id": "allowlist-name-not-in-descriptor-fails-fast",
  "title": "Commission.enabled_builtin_tools listing a name not in the Descriptor stops with commission_collision",
  "description": "Commission §4.1 — startup validation. Every name in an enabled_builtin_* allowlist MUST resolve to a Descriptor entry. A name the agent doesn't ship is a contract violation; the agent emits error_occurred(commission_collision) and agent_stopped(reason=error) before any model turn. Same fail-loud-on-drift rule as supervisor-managed asset id collisions.",
  "spec_refs": [
    "spec/v0.1/commission.md#4-built-in-surface-allowlists"
  ],
  "applies_to": ["agent"],
  "commission": {
    "schema_version": "0.1",
    "run_id": "allowlist-unknown-name",
    "model": "test/mock",
    "enabled_builtin_tools": ["Read", "Telekinesis"]
  },
  "agent_descriptor": {
    "agent_name": "test-agent",
    "agent_version": "0.0.0",
    "avp_spec_version": "0.1",
    "built_in_tools": [
      { "name": "Read" },
      { "name": "Bash" }
    ]
  },
  "agent_builtin_tools": [
    { "name": "Read", "description": "Read.", "input_schema": { "type": "object" } },
    { "name": "Bash", "description": "Bash.", "input_schema": { "type": "object" } }
  ],
  "scripted_model": [
    {
      "tokens_input": 5,
      "tokens_output": 1,
      "cost_usd": 0.0,
      "duration_ms": 1,
      "text": "should not run",
      "converged": true
    }
  ],
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      {
        "match": {
          "type": "avp.error_occurred",
          "data": { "avp.error.code": "commission_collision" }
        }
      },
      {
        "match": {
          "type": "avp.agent_stopped",
          "data": { "avp.reason": "error" }
        }
      }
    ],
    "forbidden_events": [
      {
        "label": "no model turn runs when the allowlist names a non-existent built-in",
        "match": { "type": "avp.model_turn_started" }
      }
    ]
  }
}
