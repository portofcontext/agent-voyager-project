{
  "id": "allowlist-runtime-blocks-disabled-tool",
  "title": "Model invoking a disabled built-in MUST emit tool_invoked → tool_failed and not execute",
  "description": "defense-in-depth. The visibility layer hides disabled built-ins from agent_started.data.tools[], but if the model invokes a disabled name anyway (hallucination, prompt injection from earlier tool output, prior-context leakage), the agent MUST emit tool_invoked first (the attempt is on the wire) and tool_failed second (refusing to execute). The model receives an `Error: …` tool_result so the next turn can react.",
  "spec_refs": [
    "spec/v0.1/commission.md#4-built-in-surface-allowlists"
  ],
  "applies_to": [
    "agent"
  ],
  "commission": {
    "schema_version": "0.1",
    "run_id": "allowlist-runtime-block",
    "model": "test/mock",
    "enabled_builtin_tools": [
      "Read"
    ]
  },
  "agent_descriptor": {
    "agent_name": "test-agent",
    "agent_version": "0.0.0",
    "avp_spec_version": "0.1",
    "built_in_tools": [
      {
        "name": "Read"
      },
      {
        "name": "Bash"
      }
    ]
  },
  "agent_builtin_tools": [
    {
      "name": "Read",
      "description": "Read.",
      "input_schema": {
        "type": "object"
      }
    },
    {
      "name": "Bash",
      "description": "Bash.",
      "input_schema": {
        "type": "object"
      }
    }
  ],
  "scripted_tools": {
    "Read": {
      "output": "file contents"
    },
    "Bash": {
      "output": "should not run"
    }
  },
  "scripted_model": [
    {
      "tokens_input": 5,
      "tokens_output": 2,
      "cost_usd": 0.0001,
      "duration_ms": 1,
      "tool_calls": [
        {
          "call_id": "c1",
          "tool": "Bash",
          "input": {
            "command": "ls"
          }
        }
      ],
      "converged": false
    },
    {
      "tokens_input": 4,
      "tokens_output": 2,
      "cost_usd": 0.0,
      "duration_ms": 1,
      "text": "tool was disabled, moving on",
      "converged": true
    }
  ],
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      {
        "match": {
          "type": "avp.tool_invoked",
          "data": {
            "gen_ai.tool.name": "Bash"
          }
        },
        "label": "tool_invoked still fires — the attempt is recorded"
      },
      {
        "match": {
          "type": "avp.tool_failed",
          "data": {
            "gen_ai.tool.name": "Bash"
          }
        },
        "label": "tool_failed records the runtime block"
      },
      {
        "match": {
          "type": "avp.agent_stopped",
          "data": {
            "avp.reason": "converged"
          }
        }
      }
    ],
    "forbidden_events": [
      {
        "label": "tool_returned MUST NOT fire for a disabled built-in (it never executed)",
        "match": {
          "type": "avp.tool_returned",
          "data": {
            "gen_ai.tool.name": "Bash"
          }
        }
      }
    ]
  }
}
