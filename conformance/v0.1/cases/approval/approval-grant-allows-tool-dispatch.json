{
  "id": "approval-grant-allows-tool-dispatch",
  "title": "Approval-source verifier grants → tool dispatches; aep.approval_requested/resolved pair recorded",
  "description": "A pre_tool:<name> verifier with source.approval emits aep.approval_requested when the model attempts the gated tool, awaits aep.approval_resolved from the supervisor, and dispatches the tool only when approved. Both lifecycle events MUST be recorded in the trajectory verbatim (the resolved event re-stamped with the runner's trace_id so the run is one tree). When approved=true, the verifier_evaluated MUST carry passed=true and the tool MUST dispatch normally. This is the human-in-the-loop gate a supervisor relies on for high-risk operations.",
  "spec_refs": [
    "spec/v0.1/SPEC.md#7-verifiers",
    "spec/v0.1/aep.schema.json#/$defs/ApprovalRequestedEvent",
    "spec/v0.1/aep.schema.json#/$defs/ApprovalResolvedEvent"
  ],
  "applies_to": ["runner"],
  "config": {
    "schema_version": "0.1",
    "run_id": "approve-deploy",
    "model": "test/mock",
    "verifiers": [
      {
        "name": "ask-before-deploy",
        "trigger": "pre_tool:deploy",
        "source": {
          "approval": {
            "prompt": "Deploy to prod?"
          }
        },
        "on_failure": "halt",
        "timeout_ms": 5000
      }
    ]
  },
  "scripted_model": [
    {
      "tokens_input": 10,
      "tokens_output": 5,
      "cost_usd": 0.0001,
      "duration_ms": 1,
      "tool_calls": [
        {
          "call_id": "c1",
          "tool": "deploy",
          "input": {
            "target": "prod"
          }
        }
      ],
      "converged": false
    },
    {
      "tokens_input": 5,
      "tokens_output": 3,
      "cost_usd": 0.0001,
      "duration_ms": 1,
      "text": "deployed",
      "converged": true
    }
  ],
  "scripted_tools": {
    "deploy": {
      "output": "deployed-ok"
    }
  },
  "scripted_supervisor": [
    {
      "on": {
        "match": {
          "type": "aep.approval_requested"
        }
      },
      "send": {
        "specversion": "1.0",
        "id": "{{event.id}}-resolved",
        "source": "aep://supervisor",
        "type": "aep.approval_resolved",
        "subject": "approve-deploy",
        "time": "{{now}}",
        "datacontenttype": "application/json",
        "data": {
          "trace_id": "00000000000000000000000000000000",
          "span_id": "0000000000000000",
          "parent_span_id": "0000000000000000",
          "aep.approval.id": "{{event.data.aep.approval.id}}",
          "aep.approval.approved": true,
          "aep.approval.reason": "approved by alice"
        }
      }
    }
  ],
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      {
        "match": {
          "type": "aep.approval_requested",
          "data": {
            "gen_ai.tool.name": "deploy",
            "aep.verifier.name": "ask-before-deploy",
            "aep.approval.prompt": "Deploy to prod?"
          }
        }
      },
      {
        "match": {
          "type": "aep.approval_resolved",
          "data": {
            "aep.approval.approved": true
          }
        }
      },
      {
        "match": {
          "type": "aep.verifier_evaluated",
          "data": {
            "aep.verifier.name": "ask-before-deploy",
            "aep.verifier.passed": true
          }
        }
      },
      {
        "match": {
          "type": "aep.tool_returned",
          "data": {
            "gen_ai.tool.name": "deploy"
          }
        }
      },
      {
        "match": {
          "type": "aep.agent_stopped",
          "data": {
            "aep.reason": "converged"
          }
        }
      }
    ]
  }
}
