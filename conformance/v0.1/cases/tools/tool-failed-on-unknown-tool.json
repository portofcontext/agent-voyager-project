{
  "id": "tool-failed-on-unknown-tool",
  "title": "Model invocation of an unknown tool emits tool_invoked → tool_returned (isError: true)",
  "description": "when the model invokes a tool name that is not in the agent's effective bag (no built-in match, no MCP-server match, no managed subagent), the agent MUST emit tool_invoked first, then tool_returned with avp.tool_result.isError set to true and an error message in content. The model receives an `Error: …` tool_result so the next turn can react. The wire stays well-formed; tool_failed MUST NOT fire.",
  "spec_refs": [
    "spec/v0.1/trajectory.md#4-tool-dispatch",
    "spec/v0.1/trajectory.md#8-conformance"
  ],
  "applies_to": [
    "agent"
  ],
  "commission": {
    "schema_version": "0.1",
    "run_id": "tool-unknown",
    "model": "test/mock"
  },
  "scripted_model": [
    {
      "tokens_input": 12,
      "tokens_output": 3,
      "cost_usd": 0.0001,
      "duration_ms": 1,
      "tool_calls": [
        {
          "call_id": "c1",
          "tool": "does_not_exist",
          "input": {
            "x": 1
          }
        }
      ],
      "converged": false
    },
    {
      "tokens_input": 6,
      "tokens_output": 2,
      "cost_usd": 0.0,
      "duration_ms": 1,
      "text": "no such tool",
      "converged": true
    }
  ],
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      {
        "match": {
          "type": "avp.tool_invoked",
          "data": {
            "gen_ai.tool.name": "does_not_exist"
          }
        }
      },
      {
        "match": {
          "type": "avp.tool_returned",
          "data": {
            "gen_ai.tool.name": "does_not_exist",
            "avp.tool_result": {
              "isError": true
            }
          }
        }
      },
      {
        "match": {
          "type": "avp.agent_stopped",
          "data": {
            "avp.reason": "converged"
          }
        }
      }
    ],
    "forbidden_events": [
      {
        "label": "tool_failed MUST NOT fire; tool_returned with isError covers all outcomes",
        "match": {
          "type": "avp.tool_failed",
          "data": {
            "gen_ai.tool.name": "does_not_exist"
          }
        }
      }
    ]
  }
}
