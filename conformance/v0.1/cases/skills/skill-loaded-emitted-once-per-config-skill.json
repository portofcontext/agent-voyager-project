{
  "id": "skill-loaded-emitted-once-per-config-skill",
  "title": "skill_loaded fires once per Commission.skills entry, after agent_started, before any model turn",
  "description": "SPEC.md §9.3 normative loop: 'emit skill_loaded for each loaded skill' between agent_started and the first model_turn_started. Pins (a) the count is exactly len(Commission.skills), (b) ordering is preserved, (c) every event carries the skill name and source. Custom skill loaders that fail to fetch a SKILL.md MUST still emit skill_loaded for trajectory completeness (per Skill.source description in the schema).",
  "spec_refs": [
    "spec/v0.1/SPEC.md#9-the-runner-loop",
    "spec/v0.1/avp.schema.json#/$defs/Skill"
  ],
  "applies_to": [
    "runner"
  ],
  "config": {
    "schema_version": "0.1",
    "run_id": "skills-loaded",
    "model": "test/mock",
    "skills": [
      {
        "name": "style-guide",
        "avp.source": "./skills/style-guide"
      },
      {
        "name": "domain-glossary",
        "avp.source": "anthropic:domain-glossary@1.0"
      },
      {
        "name": "unknown-scheme",
        "avp.source": "future-scheme:foo"
      }
    ]
  },
  "scripted_model": [
    {
      "tokens_input": 10,
      "tokens_output": 5,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "done",
      "converged": true
    }
  ],
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      {
        "match": {
          "type": "avp.agent_started"
        }
      },
      {
        "match": {
          "type": "avp.skill_loaded",
          "data": {
            "avp.skill.name": "style-guide",
            "avp.skill.source": "./skills/style-guide"
          }
        }
      },
      {
        "match": {
          "type": "avp.skill_loaded",
          "data": {
            "avp.skill.name": "domain-glossary",
            "avp.skill.source": "anthropic:domain-glossary@1.0"
          }
        }
      },
      {
        "match": {
          "type": "avp.skill_loaded",
          "data": {
            "avp.skill.name": "unknown-scheme",
            "avp.skill.source": "future-scheme:foo"
          }
        }
      },
      {
        "match": {
          "type": "avp.model_turn_started"
        }
      }
    ]
  }
}
