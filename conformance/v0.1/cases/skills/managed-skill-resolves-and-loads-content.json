{
  "id": "managed-skill-resolves-and-loads-content",
  "title": "Resolved managed skill emits managed_ref_resolved and agent_started lists the skill",
  "description": "when the resolver returns SKILL.md content for a Commission.skills[] ref, the agent MUST emit managed_ref_resolved (kind=skill) and list the skill on agent_started.data.skills[]. No skill_loaded event exists on the wire; how the content enters the model's context is an agent implementation detail.",
  "spec_refs": [
    "spec/v0.1/resolver.md#3-the-avpresolve-method",
    "spec/v0.1/trajectory.md#6-skills"
  ],
  "applies_to": [
    "agent"
  ],
  "commission": {
    "schema_version": "0.1",
    "run_id": "skill-happy-path",
    "model": "test/mock",
    "skills": [
      {
        "id": "style-guide",
        "ref": {
          "type": "custom",
          "skill_id": "skill_styleguide_v3"
        }
      }
    ]
  },
  "agent_descriptor": {
    "agent_name": "test-agent",
    "agent_version": "0.0.0",
    "avp_spec_version": "0.1"
  },
  "scripted_resolver": {
    "resolutions": {
      "skill:style-guide": {
        "result": {
          "name": "style-guide",
          "description": "Project style guide.",
          "content": "Always use 4-space indentation. Prefer named exports."
        }
      }
    }
  },
  "scripted_model": [
    {
      "tokens_input": 12,
      "tokens_output": 4,
      "cost_usd": 0.0001,
      "duration_ms": 1,
      "text": "ack",
      "converged": true
    }
  ],
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      {
        "match": {
          "type": "avp.managed_ref_resolved",
          "data": {
            "avp.managed.kind": "skill",
            "avp.managed.id": "style-guide"
          }
        }
      },
      {
        "label": "agent_started lists the managed skill by id",
        "match": {
          "type": "avp.agent_started",
          "data": {
            "skills": [
              {
                "name": "style-guide"
              }
            ]
          }
        }
      },
      {
        "match": {
          "type": "avp.agent_stopped",
          "data": {
            "avp.reason": "converged"
          }
        }
      }
    ]
  }
}
