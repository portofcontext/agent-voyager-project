{
  "id": "tool-exec-resolved-output-json-passes-through",
  "title": "tool_exec_resolved.output_json reaches tool_returned.output_json verbatim",
  "description": "SPEC.md §8 normative: structured output the supervisor's RPC service returns MUST be made available to consumers via tool_returned.output_json. The runner MUST also set output to a string representation. This case pins the structured-payload passthrough so analyzers can rely on it.",
  "spec_refs": [
    "spec/v0.1/SPEC.md#8-tools"
  ],
  "applies_to": [
    "runner"
  ],
  "config": {
    "schema_version": "0.1",
    "run_id": "tool-exec-json-passthrough",
    "tools": [
      {
        "name": "lookup_user",
        "description": "Returns a structured user record.",
        "inputSchema": {
          "type": "object",
          "properties": {},
          "additionalProperties": true
        },
        "_meta": {
          "aep": {
            "timeout_ms": 1000
          }
        }
      }
    ],
    "model": "test/mock"
  },
  "scripted_model": [
    {
      "tokens_input": 50,
      "tokens_output": 10,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "looking up",
      "tool_calls": [
        {
          "call_id": "c1",
          "tool": "lookup_user",
          "input": {
            "email": "a@b.c"
          }
        }
      ],
      "converged": false
    },
    {
      "tokens_input": 10,
      "tokens_output": 5,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "done",
      "converged": true
    }
  ],
  "scripted_supervisor": [
    {
      "on": {
        "match": {
          "type": "aep.tool_exec_request",
          "data": {
            "gen_ai.tool.name": "lookup_user"
          }
        }
      },
      "send": {
        "specversion": "1.0",
        "id": "c904190b-4629-4c57-a0f8-da8a5917bbef",
        "source": "aep://supervisor",
        "type": "aep.tool_exec_resolved",
        "subject": "tool-exec-json-passthrough",
        "time": "2026-05-04T18:00:00Z",
        "datacontenttype": "application/json",
        "data": {
          "trace_id": "00000000000000000000000000000000",
          "span_id": "0000000000000000",
          "parent_span_id": "0000000000000000",
          "aep.request_id": "{{event.data.aep.request_id}}",
          "rpc": {
            "jsonrpc": "2.0",
            "id": "{{event.data.aep.request_id}}",
            "result": {
              "id": "u-42",
              "name": "Alice"
            }
          }
        }
      }
    }
  ],
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      {
        "match": {
          "type": "aep.tool_exec_resolved",
          "source": "aep://supervisor",
          "data": {
            "rpc": {
              "result": {
                "id": "u-42",
                "name": "Alice"
              }
            }
          }
        }
      },
      {
        "match": {
          "type": "aep.tool_returned",
          "data": {
            "gen_ai.tool.name": "lookup_user",
            "aep.tool.result.structured": {
              "id": "u-42",
              "name": "Alice"
            }
          }
        }
      }
    ]
  }
}
