{
  "id": "tool-exec-resolved-output-json-passes-through",
  "title": "tool_exec_resolved.output_json reaches tool_returned.output_json verbatim",
  "description": "SPEC.md §8 normative: structured output the supervisor's RPC service returns MUST be made available to consumers via tool_returned.output_json. The runner MUST also set output to a string representation. This case pins the structured-payload passthrough so analyzers can rely on it.",
  "spec_refs": ["spec/v0.1/SPEC.md#8-tools"],
  "applies_to": ["runner"],
  "config": {
    "schema_version": "0.1",
    "run_id": "tool-exec-json-passthrough",
    "tools": [
      {
        "name": "lookup_user",
        "description": "Returns a structured user record.",
        "input_schema": { "type": "object", "properties": {}, "additionalProperties": true },
        "timeout_ms": 1000
      }
    ],
    "model": "test/mock"
  },
  "scripted_model": [
    {
      "tokens_input": 50, "tokens_output": 10, "cost_usd": 0.001, "duration_ms": 1, "text": "looking up",
      "tool_calls": [{ "call_id": "c1", "tool": "lookup_user", "input": { "email": "a@b.c" } }],
      "converged": false
    },
    { "tokens_input": 10, "tokens_output": 5, "cost_usd": 0.001, "duration_ms": 1, "text": "done", "converged": true }
  ],
  "scripted_supervisor": [
    {
      "on": { "match": { "type": "tool_exec_request", "tool": "lookup_user" } },
      "send": {
        "type": "tool_exec_resolved",
        "source": "supervisor",
        "run_id": "tool-exec-json-passthrough",
        "ts": "2026-05-04T18:00:00Z",
        "request_id": "{{event.request_id}}",
        "output": "{\"id\": \"u-42\", \"name\": \"Alice\"}",
        "output_json": { "id": "u-42", "name": "Alice" }
      }
    }
  ],
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      { "match": { "type": "tool_exec_resolved", "source": "supervisor", "output_json": { "id": "u-42", "name": "Alice" } } },
      { "match": { "type": "tool_returned", "tool": "lookup_user", "output_json": { "id": "u-42", "name": "Alice" } } }
    ]
  }
}
