{
  "id": "tool-exec-resolved-error-prefixes-output-with-error",
  "title": "tool_exec_resolved with JSON-RPC error: tool_returned.aep.tool.result.text MUST be prefixed with 'Error: '",
  "description": "SPEC.md §8 normative: 'If tool_exec_resolved.data.rpc.error is set, the runner MUST prefix `Error: ` before returning to the model.' The supervisor's RPC reply carries a JSON-RPC error with message='lookup failed'; the runner MUST yield tool_returned.aep.tool.result.text = 'Error: lookup failed'.",
  "spec_refs": [
    "spec/v0.1/SPEC.md#8-tools"
  ],
  "applies_to": [
    "runner"
  ],
  "config": {
    "schema_version": "0.1",
    "run_id": "tool-exec-error-prefix",
    "tools": [
      {
        "name": "lookup_user",
        "description": "Lookup tool the supervisor will reply to with an error.",
        "inputSchema": {
          "type": "object",
          "properties": {},
          "additionalProperties": true
        },
        "_meta": {
          "aep": {
            "timeout_ms": 1000
          }
        }
      }
    ],
    "model": "test/mock"
  },
  "scripted_model": [
    {
      "tokens_input": 50,
      "tokens_output": 10,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "looking up",
      "tool_calls": [
        {
          "call_id": "c1",
          "tool": "lookup_user",
          "input": {
            "email": "x@y.z"
          }
        }
      ],
      "converged": false
    },
    {
      "tokens_input": 10,
      "tokens_output": 5,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "done",
      "converged": true
    }
  ],
  "scripted_supervisor": [
    {
      "on": {
        "match": {
          "type": "aep.tool_exec_request",
          "data": {
            "gen_ai.tool.name": "lookup_user"
          }
        }
      },
      "send": {
        "specversion": "1.0",
        "id": "3749214e-24b5-48f9-b3ad-de813e19b1a0",
        "source": "aep://supervisor",
        "type": "aep.tool_exec_resolved",
        "subject": "tool-exec-error-prefix",
        "time": "2026-05-04T18:00:00Z",
        "datacontenttype": "application/json",
        "data": {
          "trace_id": "00000000000000000000000000000000",
          "span_id": "0000000000000000",
          "parent_span_id": "0000000000000000",
          "aep.request_id": "{{event.data.aep.request_id}}",
          "rpc": {
            "jsonrpc": "2.0",
            "id": "{{event.data.aep.request_id}}",
            "error": {
              "code": -32000,
              "message": "lookup failed"
            }
          }
        }
      }
    }
  ],
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      {
        "match": {
          "type": "aep.tool_exec_request",
          "data": {
            "gen_ai.tool.name": "lookup_user"
          }
        }
      },
      {
        "match": {
          "type": "aep.tool_exec_resolved",
          "source": "aep://supervisor",
          "data": {
            "rpc": {
              "error": {
                "message": "lookup failed"
              }
            }
          }
        }
      },
      {
        "match": {
          "type": "aep.tool_returned",
          "data": {
            "gen_ai.tool.name": "lookup_user",
            "aep.tool.result.text": "Error: lookup failed"
          }
        }
      }
    ]
  }
}
