{
  "id": "tool-exec-resolved-error-prefixes-output-with-error",
  "title": "tool_exec_resolved with `error` set: tool_returned.output MUST be prefixed with 'Error: '",
  "description": "SPEC.md §8 normative: 'If tool_exec_resolved.error is set, the runner MUST prefix `Error: ` before returning to the model.' This case pins that exact rule. The supervisor's RPC reply carries error='lookup failed' and output='no such user'; the runner MUST yield tool_returned.output = 'Error: no such user'.",
  "spec_refs": ["spec/v0.1/SPEC.md#8-tools"],
  "applies_to": ["runner"],
  "config": {
    "schema_version": "0.1",
    "run_id": "tool-exec-error-prefix",
    "tools": [
      {
        "name": "lookup_user",
        "description": "Lookup tool the supervisor will reply to with an error.",
        "input_schema": { "type": "object", "properties": {}, "additionalProperties": true },
        "timeout_ms": 1000
      }
    ],
    "model": "test/mock"
  },
  "scripted_model": [
    {
      "tokens_input": 50, "tokens_output": 10, "cost_usd": 0.001, "duration_ms": 1, "text": "looking up",
      "tool_calls": [{ "call_id": "c1", "tool": "lookup_user", "input": { "email": "x@y.z" } }],
      "converged": false
    },
    { "tokens_input": 10, "tokens_output": 5, "cost_usd": 0.001, "duration_ms": 1, "text": "done", "converged": true }
  ],
  "scripted_supervisor": [
    {
      "on": { "match": { "type": "tool_exec_request", "tool": "lookup_user" } },
      "send": {
        "type": "tool_exec_resolved",
        "source": "supervisor",
        "run_id": "tool-exec-error-prefix",
        "ts": "2026-05-04T18:00:00Z",
        "request_id": "{{event.request_id}}",
        "output": "no such user",
        "error": "lookup failed"
      }
    }
  ],
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      { "match": { "type": "tool_exec_request", "tool": "lookup_user" } },
      { "match": { "type": "tool_exec_resolved", "source": "supervisor", "error": "lookup failed" } },
      { "match": { "type": "tool_returned", "tool": "lookup_user", "output": "Error: no such user" } }
    ]
  }
}
