{
  "id": "subagent-invoked-and-returned-pair-frame-span",
  "title": "Parent agent's subagent invocation emits subagent_invoked \u2192 subagent_returned pair sharing one frame span_id",
  "description": "Subagents are a Commission primitive alongside tools and skills. When the parent agent calls a declared subagent by name, the agent MUST route the call through the subagent lifecycle (NOT the tool lifecycle): emit subagent_invoked at frame open, run the subagent, emit subagent_returned at frame close. The two events MUST share span_id so consumers can pair them and reconstruct the nested span tree.",
  "spec_refs": [
    "spec/v0.1/SPEC.md#subagents"
  ],
  "applies_to": [
    "agent"
  ],
  "commission": {
    "schema_version": "0.1",
    "run_id": "subagent-pair",
    "model": "test/mock",
    "subagents": [
      {
        "name": "researcher",
        "description": "Looks things up.",
        "system_prompt": "You are a researcher.",
        "model": "test/mock"
      }
    ],
    "exposed": [
      "*"
    ]
  },
  "scripted_model": [
    {
      "tokens_input": 50,
      "tokens_output": 10,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "tool_calls": [
        {
          "call_id": "c1",
          "tool": "researcher",
          "input": {
            "prompt": "find auth handlers"
          }
        }
      ],
      "converged": false
    },
    {
      "tokens_input": 20,
      "tokens_output": 5,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "got it, done",
      "converged": true
    }
  ],
  "scripted_subagents": {
    "researcher": {
      "text": "Found 3 handlers in src/auth/.",
      "reason": "converged",
      "duration_ms": 50,
      "usage": {
        "total_cost_usd": 0.0008,
        "total_tokens": 75,
        "total_turns": 1,
        "tokens_input_total": 50,
        "tokens_output_total": 25
      }
    }
  },
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      {
        "match": {
          "type": "avp.subagent_invoked",
          "data": {
            "gen_ai.agent.name": "researcher",
            "gen_ai.agent.description": "Looks things up.",
            "gen_ai.operation.name": "invoke_agent",
            "avp.subagent.input": {
              "prompt": "find auth handlers"
            }
          }
        },
        "label": "subagent_invoked names the declared subagent and carries the parent's input"
      },
      {
        "match": {
          "type": "avp.subagent_returned",
          "data": {
            "gen_ai.agent.name": "researcher",
            "avp.subagent.result.text": "Found 3 handlers in src/auth/.",
            "avp.subagent.reason": "converged"
          }
        },
        "label": "subagent_returned carries the result text and stop reason"
      },
      {
        "match": {
          "type": "avp.agent_stopped",
          "data": {
            "avp.reason": "converged"
          }
        },
        "label": "parent run converges after subagent returns"
      }
    ],
    "forbidden_events": [
      {
        "match": {
          "type": "avp.tool_invoked",
          "data": {
            "gen_ai.tool.name": "researcher"
          }
        },
        "label": "subagent invocation MUST NOT also surface as tool_invoked"
      },
      {
        "match": {
          "type": "avp.tool_returned",
          "data": {
            "gen_ai.tool.name": "researcher"
          }
        },
        "label": "subagent invocation MUST NOT also surface as tool_returned"
      }
    ]
  }
}
