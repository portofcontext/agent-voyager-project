{
  "id": "subagent-invoked-and-returned-pair-frame-span",
  "title": "Managed subagent invocation emits subagent_invoked \u2192 subagent_returned pair sharing one frame span_id, with avp.subagent.run_id set",
  "description": "Subagents are a Commission primitive alongside mcp_servers and skills. When the parent agent calls a declared subagent by id, the agent MUST route through the subagent lifecycle (not the tool lifecycle): emit subagent_invoked at frame open, call avp.spawn_subagent against the resolver, emit subagent_returned at frame close. The two events share span_id; subagent_invoked carries avp.subagent.run_id (the child's run identifier) so consumers can correlate parent and child trajectories.",
  "spec_refs": [
    "spec/v0.1/SPEC.md#9-5-subagents",
    "spec/v0.1/SPEC.md#6-3-the-avp-spawn-subagent-method"
  ],
  "applies_to": [
    "agent"
  ],
  "commission": {
    "schema_version": "0.1",
    "run_id": "subagent-pair",
    "model": "test/mock",
    "subagents": [
      {
        "id": "researcher",
        "ref": "sk_subagent_researcher_v1"
      }
    ]
  },
  "agent_manifest": {
    "agent_name": "test-agent",
    "agent_version": "0.0.0",
    "avp_spec_version": "0.1"
  },
  "scripted_resolver": {
    "resolutions": {
      "subagent:researcher": {
        "result": {
          "name": "researcher",
          "description": "Looks things up.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "prompt": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "subagent_spawns": {
      "researcher": {
        "child_run_id": "sub-subagent-pair-researcher-1",
        "text": "Found 3 handlers in src/auth/.",
        "reason": "converged",
        "duration_ms": 50,
        "usage": {
          "total_cost_usd": 0.0008,
          "total_tokens": 75,
          "total_turns": 1,
          "tokens_input_total": 50,
          "tokens_output_total": 25
        }
      }
    }
  },
  "scripted_model": [
    {
      "tokens_input": 50,
      "tokens_output": 10,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "tool_calls": [
        {
          "call_id": "c1",
          "tool": "researcher",
          "input": {
            "prompt": "find auth handlers"
          }
        }
      ],
      "converged": false
    },
    {
      "tokens_input": 20,
      "tokens_output": 5,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "got it, done",
      "converged": true
    }
  ],
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      {
        "match": {
          "type": "avp.managed_ref_resolved",
          "data": {
            "avp.managed.kind": "subagent",
            "avp.managed.id": "researcher"
          }
        }
      },
      {
        "match": {
          "type": "avp.subagent_invoked",
          "data": {
            "gen_ai.agent.name": "researcher",
            "gen_ai.agent.description": "Looks things up.",
            "gen_ai.operation.name": "invoke_agent",
            "avp.subagent.run_id": "sub-subagent-pair-researcher-1",
            "avp.subagent.input": {
              "prompt": "find auth handlers"
            }
          }
        },
        "label": "subagent_invoked carries the resolved metadata, parent's input, and the child's run_id"
      },
      {
        "match": {
          "type": "avp.subagent_returned",
          "data": {
            "gen_ai.agent.name": "researcher",
            "avp.subagent.result.text": "Found 3 handlers in src/auth/.",
            "avp.subagent.reason": "converged"
          }
        },
        "label": "subagent_returned carries the result text and stop reason from the spawn outcome"
      },
      {
        "match": {
          "type": "avp.agent_stopped",
          "data": {
            "avp.reason": "converged"
          }
        }
      }
    ],
    "forbidden_events": [
      {
        "match": {
          "type": "avp.tool_invoked",
          "data": {
            "gen_ai.tool.name": "researcher"
          }
        },
        "label": "managed subagent invocation MUST NOT surface as tool_invoked"
      },
      {
        "match": {
          "type": "avp.tool_returned",
          "data": {
            "gen_ai.tool.name": "researcher"
          }
        },
        "label": "managed subagent invocation MUST NOT surface as tool_returned"
      }
    ]
  }
}
