{
  "id": "re-observation-supervisor-timeout-skips-injection",
  "title": "Re-observation (supervisor source) timeout: runner emits re_observation_timed_out and SKIPS injection for this turn",
  "description": "When a supervisor-source re_observation times out, the runner does NOT inject default content — the observation is skipped for this turn and the run proceeds. Missing observation content means missing observation, not silent fallback.",
  "spec_refs": ["spec/v0.1/SPEC.md#93-wire-flow--supervisor-source", "spec/v0.1/aep.schema.json#/$defs/ReObservationTimedOutEvent"],
  "applies_to": ["runner"],
  "config": {
    "schema_version": "0.1",
    "run_id": "re-obs-timeout",
    "re_observation": [
      {
        "name": "session_context",
        "source": { "supervisor": true },
        "trigger": "before_first_turn",
        "timeout_ms": 50
      }
    ],
    "model": "test/mock"
  },
  "scripted_model": [
    { "tokens_input": 10, "tokens_output": 5, "cost_usd": 0.001, "duration_ms": 1, "text": "done", "converged": true }
  ],
  "scripted_supervisor": [
    { "on": { "match": { "type": "re_observation_request", "name": "session_context" } }, "skip": true }
  ],
  "expectations": {
    "events": [
      { "match": { "type": "re_observation_request", "source": "runner", "name": "session_context", "timeout_ms": 50 } },
      { "match": { "type": "re_observation_timed_out", "source": "runner", "name": "session_context" } },
      { "match": { "type": "model_turn_started", "step": 1 } },
      { "match": { "type": "agent_stopped", "reason": "converged" } }
    ],
    "forbidden_events": [
      { "label": "no re_observation_resolved when supervisor never responded", "match": { "type": "re_observation_resolved" } },
      { "label": "no injection when content never arrived", "match": { "type": "re_observation_injected" } }
    ]
  }
}
