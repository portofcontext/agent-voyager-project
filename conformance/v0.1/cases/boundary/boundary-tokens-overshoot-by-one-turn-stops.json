{
  "id": "boundary-tokens-overshoot-by-one-turn-stops",
  "title": "Boundary: total_tokens > max_tokens halts after the turn that crosses the threshold (strict-greater)",
  "description": "max_tokens=600. Turn 1 contributes 500 tokens (input 400 + output 100); state.total_tokens=500. 500>600 false → continue. Turn 2 contributes 150 (input 50 + output 100); state.total_tokens=650. 650>600 true → stop. Run overshoots by 50 tokens, intentionally.",
  "spec_refs": ["spec/v0.1/SPEC.md#102-boundary-check-normative-algorithm"],
  "applies_to": ["runner"],
  "config": {
    "schema_version": "0.1",
    "run_id": "boundary-tokens-overshoot",
    "boundary": { "max_tokens": 600 },
    "model": "test/mock"
  },
  "scripted_model": [
    { "tokens_input": 400, "tokens_output": 100, "cost_usd": 0.01, "duration_ms": 1, "text": "t1", "converged": false },
    { "tokens_input": 50, "tokens_output": 100, "cost_usd": 0.001, "duration_ms": 1, "text": "t2", "converged": false }
  ],
  "expectations": {
    "events": [
      { "match": { "type": "model_turn_ended", "step": 1, "tokens_input": 400, "tokens_output": 100 } },
      { "match": { "type": "model_turn_started", "step": 2 } },
      { "match": { "type": "model_turn_ended", "step": 2 } },
      { "match": { "type": "agent_stopped", "reason": "token_limit", "total_turns": 2 } }
    ],
    "final_state": {
      "stop_reason": "token_limit",
      "total_turns": 2,
      "min_total_tokens": 650,
      "max_total_tokens": 650
    }
  }
}
