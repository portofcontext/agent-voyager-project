{
  "id": "boundary-cache-reads-count-as-input",
  "title": "Boundary: cache-read tokens count toward total_tokens (cache changes billing, not work)",
  "description": "max_tokens=600. Turn 1 reports tokens_input=500 (of which tokens_cache_read=400) plus tokens_output=100. The runner MUST count state.total_tokens=600 (NOT 200 by subtracting cache reads). Under strict-greater, 600>600 false → continue, so turn 2 starts. Turn 2 contributes 60 more tokens; state=660; 660>600 true → stop. A buggy runner that subtracted cache reads would have state=200 after turn 1, then 260 after turn 2, and would never stop here.",
  "spec_refs": [
    "spec/v0.1/SPEC.md#104-cost--token-accounting-rules-normative"
  ],
  "applies_to": [
    "runner"
  ],
  "config": {
    "schema_version": "0.1",
    "run_id": "boundary-cache-reads",
    "boundary": {
      "max_tokens": 600
    },
    "model": "test/mock"
  },
  "scripted_model": [
    {
      "tokens_input": 500,
      "tokens_output": 100,
      "tokens_cache_read": 400,
      "tokens_cache_write": 0,
      "cost_usd": 0.005,
      "duration_ms": 1,
      "text": "cached call",
      "converged": false
    },
    {
      "tokens_input": 50,
      "tokens_output": 10,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "small turn 2",
      "converged": false
    }
  ],
  "expectations": {
    "events": [
      {
        "match": {
          "type": "aep.model_turn_ended",
          "data": {
            "step": 1,
            "gen_ai.usage.input_tokens": 500,
            "gen_ai.usage.output_tokens": 100,
            "gen_ai.usage.cache_read.input_tokens": 400
          }
        }
      },
      {
        "label": "turn 2 MUST start because 600 > 600 is false under strict-greater",
        "match": {
          "type": "aep.model_turn_started",
          "data": {
            "step": 2
          }
        }
      },
      {
        "match": {
          "type": "aep.model_turn_ended",
          "data": {
            "step": 2
          }
        }
      },
      {
        "match": {
          "type": "aep.agent_stopped",
          "data": {
            "aep.reason": "token_limit"
          }
        }
      }
    ],
    "final_state": {
      "stop_reason": "token_limit",
      "total_turns": 2,
      "min_total_tokens": 660,
      "max_total_tokens": 660
    }
  }
}
