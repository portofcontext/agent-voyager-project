{
  "id": "verifier-on-failure-inject-correction-injects-message",
  "title": "Verifier with on_failure='inject_correction' and passed=false: correction_message MUST be inserted as user-role before the next turn; run continues",
  "description": "Demonstrates self-correcting agent flow without supervisor reach-in. The verifier fails, the runner emits verifier_evaluated, then injects the declared correction_message into history, then proceeds with the next turn. The agent's next turn sees the correction.",
  "spec_refs": [
    "spec/v0.1/SPEC.md#73-on_failure-actions"
  ],
  "applies_to": [
    "runner"
  ],
  "config": {
    "schema_version": "0.1",
    "run_id": "verifier-inject",
    "verifiers": [
      {
        "name": "tests-pass",
        "trigger": "after_each_turn",
        "source": {
          "shell": "false"
        },
        "on_failure": "inject_correction",
        "correction_message": "Tests are failing. Review your last change."
      }
    ],
    "model": "test/mock"
  },
  "scripted_model": [
    {
      "tokens_input": 10,
      "tokens_output": 5,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "t1",
      "converged": false
    },
    {
      "tokens_input": 10,
      "tokens_output": 5,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "fixed it",
      "converged": true
    }
  ],
  "expectations": {
    "events": [
      {
        "match": {
          "type": "aep.model_turn_ended",
          "data": {
            "step": 1
          }
        }
      },
      {
        "match": {
          "type": "aep.verifier_evaluated",
          "data": {
            "aep.verifier.name": "tests-pass",
            "aep.verifier.passed": false
          }
        }
      },
      {
        "match": {
          "type": "aep.model_turn_started",
          "data": {
            "step": 2
          }
        }
      },
      {
        "match": {
          "type": "aep.agent_stopped",
          "data": {
            "aep.reason": "converged",
            "aep.total_turns": 2
          }
        }
      }
    ],
    "forbidden_events": [
      {
        "label": "inject_correction MUST NOT halt the run",
        "match": {
          "type": "aep.agent_stopped",
          "data": {
            "aep.reason": "verifier_failed"
          }
        }
      }
    ]
  }
}
