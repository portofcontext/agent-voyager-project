{
  "id": "verifier-trigger-at-end-fires-before-agent-stopped",
  "title": "trigger 'at_end' fires once after the final model turn and BEFORE agent_stopped",
  "description": "SPEC.md §7.2: at_end fires once after the final turn, before agent_stopped. This is the single-shot post-flight slot. Pins that the verifier_evaluated event MUST precede agent_stopped in the trajectory and MUST fire exactly once even when the run did multiple turns.",
  "spec_refs": [
    "spec/v0.1/SPEC.md#72-triggers",
    "spec/v0.1/SPEC.md#9-the-runner-loop"
  ],
  "applies_to": [
    "runner"
  ],
  "config": {
    "schema_version": "0.1",
    "run_id": "verifier-at-end",
    "verifiers": [
      {
        "name": "post-flight-check",
        "trigger": "at_end",
        "source": {
          "shell": "true"
        },
        "on_failure": "continue"
      }
    ],
    "model": "test/mock"
  },
  "scripted_model": [
    {
      "tokens_input": 50,
      "tokens_output": 10,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "turn 1",
      "converged": false
    },
    {
      "tokens_input": 50,
      "tokens_output": 10,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "turn 2",
      "converged": false
    },
    {
      "tokens_input": 10,
      "tokens_output": 5,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "done",
      "converged": true
    }
  ],
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      {
        "match": {
          "type": "aep.model_turn_ended",
          "data": {
            "step": 3
          }
        }
      },
      {
        "match": {
          "type": "aep.verifier_evaluated",
          "data": {
            "aep.verifier.name": "post-flight-check",
            "aep.verifier.passed": true
          }
        }
      },
      {
        "match": {
          "type": "aep.agent_stopped",
          "data": {
            "aep.reason": "converged"
          }
        }
      }
    ]
  }
}
