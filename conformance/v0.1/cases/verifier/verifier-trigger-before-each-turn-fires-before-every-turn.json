{
  "id": "verifier-trigger-before-each-turn-fires-before-every-turn",
  "title": "trigger 'before_each_turn' fires before EVERY model_turn_started, not just turn 1",
  "description": "SPEC.md §7.2: before_each_turn fires before every model_turn_started. With a 3-turn run, the verifier_evaluated event MUST appear three times, each immediately before the matching model_turn_started.",
  "spec_refs": ["spec/v0.1/SPEC.md#72-triggers"],
  "applies_to": ["runner"],
  "config": {
    "schema_version": "0.1",
    "run_id": "verifier-before-each",
    "verifiers": [
      {
        "name": "pre-turn-gate",
        "trigger": "before_each_turn",
        "source": { "shell": "true" },
        "on_failure": "continue"
      }
    ],
    "model": "test/mock"
  },
  "scripted_model": [
    { "tokens_input": 50, "tokens_output": 10, "cost_usd": 0.001, "duration_ms": 1, "text": "1", "converged": false },
    { "tokens_input": 50, "tokens_output": 10, "cost_usd": 0.001, "duration_ms": 1, "text": "2", "converged": false },
    { "tokens_input": 10, "tokens_output": 5, "cost_usd": 0.001, "duration_ms": 1, "text": "done", "converged": true }
  ],
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      { "match": { "type": "verifier_evaluated", "name": "pre-turn-gate" } },
      { "match": { "type": "model_turn_started", "step": 1 } },
      { "match": { "type": "verifier_evaluated", "name": "pre-turn-gate" } },
      { "match": { "type": "model_turn_started", "step": 2 } },
      { "match": { "type": "verifier_evaluated", "name": "pre-turn-gate" } },
      { "match": { "type": "model_turn_started", "step": 3 } }
    ]
  }
}
