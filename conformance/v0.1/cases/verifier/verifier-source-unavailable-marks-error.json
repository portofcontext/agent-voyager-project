{
  "id": "verifier-source-unavailable-marks-error",
  "title": "Missing verifier script: passed=false AND error='source_unavailable'",
  "description": "SPEC.md §7.4 + §13.1.18: when a verifier's source can't be located (e.g., shell exit 127 'command not found'), the runner MUST emit verifier_evaluated with passed=false AND error='source_unavailable'. This distinguishes a broken environment from a legitimate rule failure so consumers don't conflate them. The same Config in two deployments — one with the script present, one without — would otherwise be indistinguishable on the wire.",
  "spec_refs": [
    "spec/v0.1/SPEC.md#74-wire-flow",
    "spec/v0.1/aep.schema.json#/$defs/VerifierEvaluatedEvent"
  ],
  "applies_to": [
    "runner"
  ],
  "config": {
    "schema_version": "0.1",
    "run_id": "verifier-source-unavailable",
    "verifiers": [
      {
        "name": "missing-rule",
        "trigger": "after_each_turn",
        "source": {
          "shell": "/no/such/path/that/exists/scripts/never_there.sh"
        },
        "on_failure": "continue"
      }
    ],
    "model": "test/mock"
  },
  "scripted_model": [
    {
      "tokens_input": 10,
      "tokens_output": 5,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "done",
      "converged": true
    }
  ],
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      {
        "match": {
          "type": "aep.verifier_evaluated",
          "data": {
            "aep.verifier.name": "missing-rule",
            "aep.verifier.passed": false,
            "aep.verifier.error": "source_unavailable"
          }
        }
      },
      {
        "match": {
          "type": "aep.agent_stopped",
          "data": {
            "aep.reason": "converged"
          }
        }
      }
    ]
  }
}
