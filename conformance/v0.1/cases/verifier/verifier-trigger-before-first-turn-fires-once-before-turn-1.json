{
  "id": "verifier-trigger-before-first-turn-fires-once-before-turn-1",
  "title": "trigger 'before_first_turn' fires once after agent_started and before model_turn_started for turn 1",
  "description": "SPEC.md §7.2 trigger taxonomy: before_first_turn fires once after agent_started and before turn 1. Pins ordering — the verifier_evaluated event MUST appear after agent_started and before the first model_turn_started in the trajectory.",
  "spec_refs": [
    "spec/v0.1/SPEC.md#72-triggers"
  ],
  "applies_to": [
    "runner"
  ],
  "config": {
    "schema_version": "0.1",
    "run_id": "verifier-before-first",
    "verifiers": [
      {
        "name": "preflight-check",
        "trigger": "before_first_turn",
        "source": {
          "shell": "true"
        },
        "on_failure": "continue"
      }
    ],
    "model": "test/mock"
  },
  "scripted_model": [
    {
      "tokens_input": 10,
      "tokens_output": 5,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "done",
      "converged": true
    }
  ],
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      {
        "match": {
          "type": "aep.agent_started"
        }
      },
      {
        "match": {
          "type": "aep.verifier_evaluated",
          "data": {
            "aep.verifier.name": "preflight-check",
            "aep.verifier.passed": true
          }
        }
      },
      {
        "match": {
          "type": "aep.model_turn_started",
          "data": {
            "step": 1
          }
        }
      }
    ],
    "forbidden_events": [
      {
        "label": "before_first_turn MUST fire exactly once — not after later turns",
        "match": {
          "type": "aep.verifier_evaluated",
          "data": {
            "aep.verifier.name": "preflight-check",
            "step": 2
          }
        }
      }
    ]
  }
}
