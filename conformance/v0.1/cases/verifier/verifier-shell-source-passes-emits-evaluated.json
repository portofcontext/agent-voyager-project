{
  "id": "verifier-shell-source-passes-emits-evaluated",
  "title": "Shell-source verifier with on_failure='continue': runs at the declared trigger, emits verifier_evaluated with passed=true on success",
  "description": "A verifier declared with source.shell and trigger='after_each_turn' MUST execute the shell command after the model_turn_ended, emit verifier_evaluated with source='runner' and passed=true (since 'true' exits 0), and proceed normally with on_failure='continue'.",
  "spec_refs": ["spec/v0.1/SPEC.md#7-verifiers", "spec/v0.1/aep.schema.json#/$defs/Verifier"],
  "applies_to": ["runner"],
  "config": {
    "schema_version": "0.1",
    "run_id": "verifier-shell-passes",
    "verifiers": [
      {
        "name": "always-passes",
        "trigger": "after_each_turn",
        "source": { "shell": "true" },
        "on_failure": "continue"
      }
    ],
    "model": "test/mock"
  },
  "scripted_model": [
    { "tokens_input": 10, "tokens_output": 5, "cost_usd": 0.001, "duration_ms": 1, "text": "done", "converged": true }
  ],
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      { "match": { "type": "model_turn_ended", "step": 1 } },
      { "match": { "type": "verifier_evaluated", "source": "runner", "name": "always-passes", "passed": true } },
      { "match": { "type": "agent_stopped", "reason": "converged" } }
    ],
    "forbidden_events": [
      { "label": "verifier_evaluated MUST NOT carry source=supervisor", "match": { "type": "verifier_evaluated", "source": "supervisor" } }
    ]
  }
}
