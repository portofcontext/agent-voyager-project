{
  "id": "verifier-trigger-after-each-turn-fires-after-every-turn",
  "title": "trigger 'after_each_turn' fires after EVERY model_turn_ended",
  "description": "SPEC.md §7.2: after_each_turn fires after every model_turn_ended. With a 2-turn run, the verifier_evaluated MUST appear twice — once after the first model_turn_ended (and after any tool calls in that turn), once after the second.",
  "spec_refs": [
    "spec/v0.1/SPEC.md#72-triggers"
  ],
  "applies_to": [
    "runner"
  ],
  "config": {
    "schema_version": "0.1",
    "run_id": "verifier-after-each",
    "verifiers": [
      {
        "name": "post-turn-snapshot",
        "trigger": "after_each_turn",
        "source": {
          "shell": "true"
        },
        "on_failure": "continue"
      }
    ],
    "model": "test/mock"
  },
  "scripted_model": [
    {
      "tokens_input": 50,
      "tokens_output": 10,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "1",
      "converged": false
    },
    {
      "tokens_input": 10,
      "tokens_output": 5,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "done",
      "converged": true
    }
  ],
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      {
        "match": {
          "type": "aep.model_turn_ended",
          "data": {
            "step": 1
          }
        }
      },
      {
        "match": {
          "type": "aep.verifier_evaluated",
          "data": {
            "aep.verifier.name": "post-turn-snapshot"
          }
        }
      },
      {
        "match": {
          "type": "aep.model_turn_ended",
          "data": {
            "step": 2
          }
        }
      },
      {
        "match": {
          "type": "aep.verifier_evaluated",
          "data": {
            "aep.verifier.name": "post-turn-snapshot"
          }
        }
      },
      {
        "match": {
          "type": "aep.agent_stopped",
          "data": {
            "aep.reason": "converged"
          }
        }
      }
    ]
  }
}
