{
  "id": "text-emitted-carries-assistant-content",
  "title": "text_emitted records assistant text content with the turn it came from",
  "description": "SPEC.md \u00a711: text_emitted MUST appear for every text content block the model produced. It carries `step` matching the turn that emitted it and `text` carrying the verbatim content. Pre-fix the reference agent emitted text_emitted only when the model also produced text \u2014 verify the basic shape: one model turn, one text response, one text_emitted with the text body and the matching step.",
  "spec_refs": [
    "spec/v0.1/SPEC.md#11-event-reference"
  ],
  "applies_to": [
    "agent"
  ],
  "commission": {
    "schema_version": "0.1",
    "run_id": "text-emitted-basic",
    "model": "test/mock",
    "exposed": [
      "*"
    ]
  },
  "scripted_model": [
    {
      "tokens_input": 30,
      "tokens_output": 12,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "the answer is 42. DONE.",
      "converged": true
    }
  ],
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      {
        "match": {
          "type": "avp.model_turn_started",
          "data": {
            "step": 1
          }
        }
      },
      {
        "match": {
          "type": "avp.model_turn_ended",
          "data": {
            "step": 1
          }
        }
      },
      {
        "match": {
          "type": "avp.text_emitted",
          "data": {
            "step": 1,
            "avp.text": "the answer is 42. DONE."
          }
        }
      },
      {
        "match": {
          "type": "avp.agent_stopped",
          "data": {
            "avp.reason": "converged"
          }
        }
      }
    ]
  }
}
