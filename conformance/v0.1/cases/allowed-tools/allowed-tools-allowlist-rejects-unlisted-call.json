{
  "id": "allowed-tools-allowlist-rejects-unlisted-call",
  "title": "Tool call to a name not in Commission.exposed → tool_failed (the allowlist is enforced at dispatch)",
  "description": "When Commission.exposed is set, the agent MUST reject any tool invocation whose name is not in the list. The rejection surfaces as tool_failed with an error message identifying the allowlist as the cause; the model may then react in the next turn. The first call ('bash') is allowed and returns normally; the second ('echo') is not in the allowlist and fails.",
  "spec_refs": [
    "spec/v0.1/SPEC.md#8-tools",
    "spec/v0.1/avp.schema.json#/$defs/Commission"
  ],
  "applies_to": [
    "agent"
  ],
  "commission": {
    "schema_version": "0.1",
    "run_id": "allowed-tools-rejects",
    "model": "test/mock",
    "exposed": [
      "bash"
    ]
  },
  "agent_builtin_tools": [
    {
      "name": "bash",
      "description": "Run a shell command.",
      "input_schema": {
        "type": "object",
        "properties": {
          "cmd": {
            "type": "string"
          }
        },
        "required": ["cmd"]
      }
    },
    {
      "name": "echo",
      "description": "Print a message.",
      "input_schema": {
        "type": "object",
        "properties": {
          "msg": {
            "type": "string"
          }
        },
        "required": ["msg"]
      }
    }
  ],
  "scripted_model": [
    {
      "tokens_input": 20,
      "tokens_output": 10,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "trying allowed and disallowed",
      "tool_calls": [
        {
          "call_id": "c1",
          "tool": "bash",
          "input": {
            "cmd": "true"
          }
        },
        {
          "call_id": "c2",
          "tool": "echo",
          "input": {
            "msg": "blocked"
          }
        }
      ],
      "converged": false
    },
    {
      "tokens_input": 10,
      "tokens_output": 5,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "done",
      "converged": true
    }
  ],
  "scripted_tools": {
    "bash": {
      "output": "ok",
      "duration_ms": 1
    },
    "echo": {
      "output": "should not run",
      "duration_ms": 1
    }
  },
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      {
        "match": {
          "type": "avp.tool_invoked",
          "data": {
            "gen_ai.tool.call.id": "c1",
            "gen_ai.tool.name": "bash"
          }
        }
      },
      {
        "match": {
          "type": "avp.tool_returned",
          "data": {
            "gen_ai.tool.call.id": "c1",
            "gen_ai.tool.name": "bash"
          }
        }
      },
      {
        "match": {
          "type": "avp.tool_invoked",
          "data": {
            "gen_ai.tool.call.id": "c2",
            "gen_ai.tool.name": "echo"
          }
        }
      },
      {
        "match": {
          "type": "avp.tool_failed",
          "data": {
            "gen_ai.tool.call.id": "c2",
            "gen_ai.tool.name": "echo"
          }
        }
      },
      {
        "match": {
          "type": "avp.agent_stopped",
          "data": {
            "avp.reason": "converged"
          }
        }
      }
    ],
    "forbidden_events": [
      {
        "label": "disallowed tool MUST NOT produce tool_returned",
        "match": {
          "type": "avp.tool_returned",
          "data": {
            "gen_ai.tool.call.id": "c2"
          }
        }
      }
    ]
  }
}
