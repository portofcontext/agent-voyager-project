{
  "id": "agent-started-tools-reflects-effective-surface",
  "title": "agent_started.tools lists agent built-ins filtered by allowed_tools",
  "description": "SPEC.md §13.1: agent_started.tools MUST list the EFFECTIVE tool surface. v0.1 has two paths for tools — agent-built-ins (compiled into the agent) and MCP-server tools (Commission.mcp_servers, surfaced on mcp_server_connected). This case exercises the built-in side: two agent built-ins (bash, read_file), an allowlist permitting only bash. agent_started.tools should therefore contain exactly one entry, bash. read_file is filtered out by the allowlist.",
  "spec_refs": [
    "spec/v0.1/SPEC.md#13-conformance",
    "spec/v0.1/SPEC.md#8-tools"
  ],
  "applies_to": [
    "agent"
  ],
  "commission": {
    "schema_version": "0.1",
    "run_id": "agent-started-effective-tools",
    "exposed": [
      "bash"
    ],
    "model": "test/mock"
  },
  "agent_builtin_tools": [
    {
      "name": "bash",
      "description": "Run a shell command.",
      "input_schema": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string"
          }
        },
        "required": [
          "command"
        ]
      }
    },
    {
      "name": "read_file",
      "description": "Filtered out by allowed_tools.",
      "input_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          }
        },
        "required": [
          "path"
        ]
      }
    }
  ],
  "scripted_model": [
    {
      "tokens_input": 10,
      "tokens_output": 5,
      "cost_usd": 0.001,
      "duration_ms": 1,
      "text": "done",
      "converged": true
    }
  ],
  "expectations": {
    "ordering": "in_order_subsequence",
    "events": [
      {
        "match": {
          "type": "avp.agent_started",
          "data": {
            "tools": [
              {
                "name": "bash"
              }
            ]
          }
        }
      }
    ]
  }
}
