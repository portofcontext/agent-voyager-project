{
  "$defs": {
    "BuiltinMcpServer": {
      "additionalProperties": false,
      "description": "One MCP server the case pretends the SDK has built-in.\n\nConnection material (URL, auth, command line) is irrelevant for the\nfixture; only identity surfaces, since merge logic operates on `id`.",
      "properties": {
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        }
      },
      "required": [
        "id"
      ],
      "title": "BuiltinMcpServer",
      "type": "object"
    },
    "BuiltinSkill": {
      "additionalProperties": false,
      "description": "One skill the case pretends the SDK has built-in.",
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Version"
        },
        "source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source"
        }
      },
      "required": [
        "name"
      ],
      "title": "BuiltinSkill",
      "type": "object"
    },
    "BuiltinSubagent": {
      "additionalProperties": false,
      "description": "One subagent the case pretends the SDK has built-in.",
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "input_schema": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Input Schema"
        },
        "agent_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Agent Type"
        }
      },
      "required": [
        "name"
      ],
      "title": "BuiltinSubagent",
      "type": "object"
    },
    "BuiltinTool": {
      "additionalProperties": false,
      "description": "One tool the case pretends the SDK has built-in.",
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "input_schema": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Input Schema"
        },
        "mcp_server_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mcp Server Id"
        }
      },
      "required": [
        "name"
      ],
      "title": "BuiltinTool",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Test fixture consumed by an SDK's conformance entrypoint via `--built-in <json|path>`. The SDK MUST behave as if these are its actual built-ins for the run (system_prompt, tools, skills, mcp_servers, subagents), then apply Commission overrides per the AVP merge spec. Not part of the wire format; only used by the conformance harness.",
  "properties": {
    "system_prompt": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "System Prompt"
    },
    "prompt": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Prompt"
    },
    "tools": {
      "items": {
        "$ref": "#/$defs/BuiltinTool"
      },
      "title": "Tools",
      "type": "array"
    },
    "skills": {
      "items": {
        "$ref": "#/$defs/BuiltinSkill"
      },
      "title": "Skills",
      "type": "array"
    },
    "mcp_servers": {
      "items": {
        "$ref": "#/$defs/BuiltinMcpServer"
      },
      "title": "Mcp Servers",
      "type": "array"
    },
    "subagents": {
      "items": {
        "$ref": "#/$defs/BuiltinSubagent"
      },
      "title": "Subagents",
      "type": "array"
    }
  },
  "title": "Agent Builtins",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://avp.dev/schema/v0.1/conformance/agent-built-ins.schema.json"
}
