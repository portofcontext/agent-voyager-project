{
  "$defs": {
    "McpServerHttp": {
      "additionalProperties": false,
      "description": "Inline HTTP MCP server entry in Commission.mcp_servers.",
      "properties": {
        "id": {
          "minLength": 1,
          "pattern": "^[a-z0-9_-]+$",
          "title": "Id",
          "type": "string"
        },
        "type": {
          "const": "http",
          "title": "Type",
          "type": "string"
        },
        "url": {
          "minLength": 1,
          "title": "Url",
          "type": "string"
        },
        "headers": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Headers"
        }
      },
      "required": [
        "id",
        "type",
        "url"
      ],
      "title": "McpServerHttp",
      "type": "object"
    },
    "McpServerStdio": {
      "additionalProperties": false,
      "description": "Inline stdio MCP server entry in Commission.mcp_servers.",
      "properties": {
        "id": {
          "minLength": 1,
          "pattern": "^[a-z0-9_-]+$",
          "title": "Id",
          "type": "string"
        },
        "type": {
          "const": "stdio",
          "title": "Type",
          "type": "string"
        },
        "command": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Command",
          "type": "array"
        },
        "args": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Args"
        },
        "env": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Env"
        }
      },
      "required": [
        "id",
        "type",
        "command"
      ],
      "title": "McpServerStdio",
      "type": "object"
    },
    "Skill": {
      "additionalProperties": false,
      "description": "Inline skill entry in Commission.skills.",
      "properties": {
        "id": {
          "minLength": 1,
          "pattern": "^[a-z0-9_-]+$",
          "title": "Id",
          "type": "string"
        },
        "files": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Files",
          "type": "object"
        }
      },
      "required": [
        "id",
        "files"
      ],
      "title": "Skill",
      "type": "object"
    },
    "SupervisorPreamble": {
      "additionalProperties": false,
      "description": "Identifies the supervisor that is requesting the run.\n\nCarried inside `Commission.supervisor` and projected onto the\n`run_requested` event's `data` (`avp.supervisor.name` +\n`avp.supervisor.version`) so a trajectory consumer can attribute the\nrun to the originating supervisor without an out-of-band lookup. The\nevent's `source` is `avp://agent` (the agent is the sole producer on\nthe wire); supervisor attribution lives inside `data`.\n\n`name` SHOULD be a stable identifier for the supervisor implementation\nor instance (e.g. `\"simple-supervisor-example\"`, `\"acme.scheduler\"`).\n`version` is optional but recommended; it travels with the trajectory\nand lets auditors correlate a run with the exact supervisor build\nthat requested it.",
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Version"
        }
      },
      "required": [
        "name"
      ],
      "title": "SupervisorPreamble",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Supervisor → agent setup message. Declares prompt, model, and supervisor-managed assets (mcp_servers, skills, subagents) as opaque {id, ref} pairs the agent dereferences via the AVP Resolver API at startup. Sent once at startup. See spec/v0.1/commission.md.",
  "properties": {
    "schema_version": {
      "const": "0.1",
      "title": "Schema Version",
      "type": "string"
    },
    "run_id": {
      "minLength": 1,
      "title": "Run Id",
      "type": "string"
    },
    "supervisor": {
      "anyOf": [
        {
          "$ref": "#/$defs/SupervisorPreamble"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "mcp_servers": {
      "anyOf": [
        {
          "items": {
            "discriminator": {
              "mapping": {
                "http": "#/$defs/McpServerHttp",
                "stdio": "#/$defs/McpServerStdio"
              },
              "propertyName": "type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/McpServerHttp"
              },
              {
                "$ref": "#/$defs/McpServerStdio"
              }
            ]
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Mcp Servers"
    },
    "skills": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/Skill"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Skills"
    },
    "enabled_builtin_tools": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Enabled Builtin Tools"
    },
    "enabled_builtin_subagents": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Enabled Builtin Subagents"
    },
    "enabled_builtin_skills": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Enabled Builtin Skills"
    },
    "enabled_builtin_mcp_servers": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Enabled Builtin Mcp Servers"
    },
    "output_schema": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Output Schema"
    },
    "prompt": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Prompt"
    },
    "system_prompt": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "System Prompt"
    },
    "model": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model"
    },
    "thread_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Thread Id"
    },
    "tags": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tags"
    },
    "meta": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Meta"
    }
  },
  "required": [
    "schema_version",
    "run_id"
  ],
  "title": "AVP v0.1 Commission",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://avp.dev/schema/v0.1/commission.schema.json"
}
