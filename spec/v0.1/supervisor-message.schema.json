{
  "$defs": {
    "JsonRpcError": {
      "additionalProperties": true,
      "properties": {
        "code": {
          "title": "Code",
          "type": "integer"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "data": {
          "anyOf": [
            {},
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Data"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "JsonRpcError",
      "type": "object"
    },
    "JsonRpcResponsePayload": {
      "additionalProperties": true,
      "description": "JSON-RPC 2.0 response payload — what tool_exec_resolved.data carries.\n\nExactly one of `result` or `error` MUST be present per the JSON-RPC spec.",
      "properties": {
        "jsonrpc": {
          "const": "2.0",
          "default": "2.0",
          "title": "Jsonrpc",
          "type": "string"
        },
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Id"
        },
        "result": {
          "anyOf": [
            {},
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Result"
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/$defs/JsonRpcError"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "JsonRpcResponsePayload",
      "type": "object"
    },
    "ToolExecResolvedData": {
      "additionalProperties": true,
      "description": "Wraps the JSON-RPC response. `source` URI on the envelope identifies\nwho answered (supervisor or mcp/<server_id>).\n\n`gen_ai.tool.name` echoes the request's tool name for observability —\nconsumers shouldn't need to cross-reference the request to filter replies.",
      "properties": {
        "trace_id": {
          "maxLength": 32,
          "minLength": 32,
          "pattern": "^[0-9a-f]{32}$",
          "title": "Trace Id",
          "type": "string"
        },
        "span_id": {
          "maxLength": 16,
          "minLength": 16,
          "pattern": "^[0-9a-f]{16}$",
          "title": "Span Id",
          "type": "string"
        },
        "parent_span_id": {
          "maxLength": 16,
          "minLength": 16,
          "pattern": "^[0-9a-f]{16}$",
          "title": "Parent Span Id",
          "type": "string"
        },
        "aep.request_id": {
          "minLength": 1,
          "title": "Aep.Request Id",
          "type": "string"
        },
        "gen_ai.tool.name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Gen Ai.Tool.Name"
        },
        "rpc": {
          "$ref": "#/$defs/JsonRpcResponsePayload"
        }
      },
      "required": [
        "trace_id",
        "span_id",
        "parent_span_id",
        "aep.request_id",
        "rpc"
      ],
      "title": "ToolExecResolvedData",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Supervisor (or MCP server) → runner reply. v0.1 carries only `aep.tool_exec_resolved` events. `source` is `aep://supervisor` for supervisor-routed RPCs or `aep://mcp/<server_id>` for MCP-server-routed RPCs. The payload's `data.rpc` is a JSON-RPC 2.0 response.",
  "properties": {
    "specversion": {
      "const": "1.0",
      "default": "1.0",
      "title": "Specversion",
      "type": "string"
    },
    "id": {
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "time": {
      "title": "Time",
      "type": "string"
    },
    "subject": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Subject"
    },
    "datacontenttype": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": "application/json",
      "title": "Datacontenttype"
    },
    "dataschema": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Dataschema"
    },
    "aep.correlation_id": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Aep.Correlation Id"
    },
    "type": {
      "const": "aep.tool_exec_resolved",
      "default": "aep.tool_exec_resolved",
      "title": "Type",
      "type": "string"
    },
    "source": {
      "minLength": 1,
      "title": "Source",
      "type": "string"
    },
    "data": {
      "$ref": "#/$defs/ToolExecResolvedData"
    }
  },
  "required": [
    "source",
    "data"
  ],
  "title": "AEP v0.1 SupervisorMessage",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aep.dev/schema/v0.1/supervisor-message.schema.json"
}
